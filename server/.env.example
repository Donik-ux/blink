# Скопируй в server/.env и заполни своими значениями

PORT=5000
NODE_ENV=production

# MongoDB Atlas — https://cloud.mongodb.com (бесплатно 512MB)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/blink?retryWrites=true&w=majority

# Redis — опционально. Бесплатно: https://upstash.com
REDIS_URL=redis://localhost:6379

# JWT секреты — сгенерируй случайные строки минимум 32 символа
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_random_string_32_chars_min
JWT_REFRESH_SECRET=change_me_to_another_random_string_32

# CORS — домен фронтенда (для production)
# CLIENT_URL=https://blink.vercel.app
