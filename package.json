{
  "name": "blink-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client -- --host\"",
    "install-all": "npm install --prefix server && npm install --prefix client",
    "build": "npm run build --prefix client",
    "bg:start": "pm2 start ecosystem.config.cjs && pm2 save",
    "bg:stop": "pm2 delete ecosystem.config.cjs && pm2 save --force",
    "bg:status": "pm2 status",
    "bg:logs": "pm2 logs",
    "clean": "taskkill /F /IM node.exe"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
